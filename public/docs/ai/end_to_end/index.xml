        &lt;h2&gt;&lt;font face=Georgia&gt;1、了解人工智能&lt;/font&gt;&lt;span class=&#34;hx-absolute -hx-mt-20&#34; id=&#34;font-facegeorgia1了解人工智能font&#34;&gt;&lt;/span&gt;
    &lt;a href=&#34;#font-facegeorgia1%e4%ba%86%e8%a7%a3%e4%ba%ba%e5%b7%a5%e6%99%ba%e8%83%bdfont&#34; class=&#34;subheading-anchor&#34; aria-label=&#34;Permalink for this section&#34;&gt;&lt;/a&gt;&lt;/h2&gt;&lt;h3&gt;&lt;font face=Georgia&gt;1.1、相关概念&lt;/font&gt;&lt;span class=&#34;hx-absolute -hx-mt-20&#34; id=&#34;font-facegeorgia11相关概念font&#34;&gt;&lt;/span&gt;
    &lt;a href=&#34;#font-facegeorgia11%e7%9b%b8%e5%85%b3%e6%a6%82%e5%bf%b5font&#34; class=&#34;subheading-anchor&#34; aria-label=&#34;Permalink for this section&#34;&gt;&lt;/a&gt;&lt;/h3&gt;
      </description>
    </item>
    
    <item>
      <title>2.3. CRISP-DM</title>
      <link>http://localhost:1313/docs/ai/end_to_end/crisp-dm/</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      
      <guid>http://localhost:1313/docs/ai/end_to_end/crisp-dm/</guid>
